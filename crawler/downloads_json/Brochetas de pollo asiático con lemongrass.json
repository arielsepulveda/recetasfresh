  "steps": [
    {
      "index": 1,
      "instructions": "Precalienta el horno a 220ºC. Corta la berenjena en dados de 2 cm y colócala en una fuente grande para el horno. Agrega un chorrito de aceite y salpimienta. Mezcla para que la berenjena quede bien aderezada. Hornea a media altura durante 25-30 min, hasta que la berenjena quede tierna. Remueve a mitad de cocción.",
      "instructionsHTML": "<p>Precalienta el horno a <span>220ºC</span>. Corta la <strong>berenjena</strong> en dados de 2 cm y colócala en una fuente grande para el horno. Agrega un chorrito de <strong>aceite</strong> y <strong>salpimienta</strong>. Mezcla para que la <strong>berenjena</strong> quede bien aderezada. Hornea a media altura durante 25-30 min, hasta que la <strong>berenjena</strong> quede tierna. Remueve a mitad de cocción.</p>",
      "instructionsMarkdown": "<p>Precalienta el horno a <span>220ºC</span>. Corta la <strong>berenjena</strong> en dados de 2 cm y colócala en una fuente grande para el horno. Agrega un chorrito de <strong>aceite</strong> y <strong>salpimienta</strong>. Mezcla para que la <strong>berenjena</strong> quede bien aderezada. Hornea a media altura durante 25-30 min, hasta que la <strong>berenjena</strong> quede tierna. Remueve a mitad de cocción.</p>",
      "ingredients": [],
      "utensils": [
        "59d49a9319279f8fe60e8675"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/63ca9c23812a821893bf04fe/step-9000e900.jpg",
