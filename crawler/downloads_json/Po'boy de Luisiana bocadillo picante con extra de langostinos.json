  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nSeca los langostinos y colócalos en un bol.\nAñade la mitad de las especias cajún, chili en escamas al gusto, un chorrito de aceite, sal y pimienta.\nRemueve y reserva en la nevera hasta el paso 3.\nPela y ralla el ajo.\n\nRECUERDA: Lávate las manos y los utensilios de cocina después de manipular marisco crudo.",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Seca los <strong>langostinos</strong> y colócalos en un bol.</li>\n<li>Añade la mitad de las <strong>especias cajún, chili en escamas</strong> al gusto, un chorrito de <strong>aceite, sal</strong> y <strong>pimienta.</strong></li>\n<li>Remueve y reserva en la nevera hasta el paso 3.</li>\n<li>Pela y ralla el <strong>ajo.</strong></li>\n</ul>\n<p>RECUERDA: Lávate las manos y los utensilios de cocina después de manipular marisco crudo.</p>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Seca los <strong>langostinos</strong> y colócalos en un bol.</li>\n<li>Añade la mitad de las <strong>especias cajún, chili en escamas</strong> al gusto, un chorrito de <strong>aceite, sal</strong> y <strong>pimienta.</strong></li>\n<li>Remueve y reserva en la nevera hasta el paso 3.</li>\n<li>Pela y ralla el <strong>ajo.</strong></li>\n</ul>\n<p>RECUERDA: Lávate las manos y los utensilios de cocina después de manipular marisco crudo.</p>",
      "ingredients": [],
      "utensils": [
        "57e2674fb7e8697d4b305369",
        "57e2674fb7e8697d4b305385"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/6952a8171676be04156eabd3/step-c6414000.jpg",
