  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nDesmenuza el tofu en trozos pequeños y reserva en un bol. Sécalo presionando ligeramente.\nDeshoja y pica la menta.\nPela y ralla la cebolla.\nPela y ralla el ajo.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Desmenuza el <strong>tofu</strong> en trozos pequeños y reserva en un bol. Sécalo presionando ligeramente.</li>\n<li>Deshoja y pica la <strong>menta</strong>.</li>\n<li>Pela y ralla la <strong>cebolla.</strong></li>\n<li>Pela y ralla el <strong>ajo</strong>.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Desmenuza el <strong>tofu</strong> en trozos pequeños y reserva en un bol. Sécalo presionando ligeramente.</li>\n<li>Deshoja y pica la <strong>menta</strong>.</li>\n<li>Pela y ralla la <strong>cebolla.</strong></li>\n<li>Pela y ralla el <strong>ajo</strong>.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
