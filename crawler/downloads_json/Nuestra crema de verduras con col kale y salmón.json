  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 200ºC.\nRetira las raíces y el extremo verde del puerro y deséchalos. Córtalo por la mitad a lo largo y, luego, pícalo finamente.\nPela y pica finamente el ajo.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 200ºC.</li>\n<li>Retira las raíces y el extremo verde del <strong>puerro</strong> y deséchalos. Córtalo por la mitad a lo largo y, luego, pícalo finamente.</li>\n<li>Pela y pica finamente el <strong>ajo</strong>.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 200ºC.</li>\n<li>Retira las raíces y el extremo verde del <strong>puerro</strong> y deséchalos. Córtalo por la mitad a lo largo y, luego, pícalo finamente.</li>\n<li>Pela y pica finamente el <strong>ajo</strong>.</li>\n</ul>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/692dc0e11ca49f0d8bd388ca/step-7d3d1e00.jpg",
