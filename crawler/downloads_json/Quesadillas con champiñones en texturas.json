  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nPela la cebolla y corta en tiras finas.\nLimpia los champiñones con un paño húmedo y retira el extremo del pie . Luego, córtalos en láminas finas.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Pela la <strong>cebolla</strong> y corta en tiras finas.</li>\n<li>Limpia los <strong>champiñones</strong> con un paño húmedo y retira el extremo del pie . Luego, córtalos en láminas finas.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Pela la <strong>cebolla</strong> y corta en tiras finas.</li>\n<li>Limpia los <strong>champiñones</strong> con un paño húmedo y retira el extremo del pie . Luego, córtalos en láminas finas.</li>\n</ul>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/67af6cc1d64ebc5b3d61783f/step-638ef100.jpg",
