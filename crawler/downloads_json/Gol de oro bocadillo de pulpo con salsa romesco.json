  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220°C.\nPela la cebolla y corta en tiras de 2 cm.\nCorta el pimiento en cuadrados de 2 cm.\nCorta el tomate a cuartos.\nCorta las patatas en dados de 2-3 cm.\n",
      "instructionsHTML": "<p><strong>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</strong></p>\n<ul>\n<li>Precalienta el horno a 220°C.</li>\n<li>Pela la <strong>cebolla</strong> y corta en tiras de 2 cm.</li>\n<li>Corta el <strong>pimiento</strong> en cuadrados de 2 cm.</li>\n<li>Corta el <strong>tomate</strong> a cuartos.</li>\n<li>Corta las <strong>patatas</strong> en dados de 2-3 cm.</li>\n</ul>",
      "instructionsMarkdown": "<p><strong>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</strong></p>\n<ul>\n<li>Precalienta el horno a 220°C.</li>\n<li>Pela la <strong>cebolla</strong> y corta en tiras de 2 cm.</li>\n<li>Corta el <strong>pimiento</strong> en cuadrados de 2 cm.</li>\n<li>Corta el <strong>tomate</strong> a cuartos.</li>\n<li>Corta las <strong>patatas</strong> en dados de 2-3 cm.</li>\n</ul>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/6818941e939c9c3068923514/step-345d8800.jpg",
