  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nRetira el extremo de la berenjena y córtala en rodajas de 1 cm.\nPela la cebolla y córtala en tiras finas.\nRetira los extremos del calabacín y córtalo por la mitad a lo largo. Corta cada mitad en medias lunas de 0,5-1 cm.\nCorta el tomate en rodajas finas.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Retira el extremo de la <strong>berenjena </strong>y córtala en rodajas de 1 cm.</li>\n<li>Pela la <strong>cebolla</strong> y córtala en tiras finas.</li>\n<li>Retira los extremos del <strong>calabacín </strong>y córtalo por la mitad a lo largo. Corta cada mitad en medias lunas de 0,5-1 cm.</li>\n<li>Corta el <strong>tomate </strong>en rodajas finas.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Retira el extremo de la <strong>berenjena </strong>y córtala en rodajas de 1 cm.</li>\n<li>Pela la <strong>cebolla</strong> y córtala en tiras finas.</li>\n<li>Retira los extremos del <strong>calabacín </strong>y córtalo por la mitad a lo largo. Corta cada mitad en medias lunas de 0,5-1 cm.</li>\n<li>Corta el <strong>tomate </strong>en rodajas finas.</li>\n</ul>",
      "ingredients": [],
      "utensils": [],
