  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de respetar bien las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220 °C.\nPela y pica el ajo.\nPela la chalota y córtala en tiras finas.\nCorta los tomates por la mitad y colócalos hacia arriba en una bandeja de horno con papel de horno.\n",
      "instructionsHTML": "<p>¡Asegúrate de respetar bien las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220 °C.</li>\n<li>Pela y pica el <strong>ajo.</strong></li>\n<li>Pela la <strong>chalota</strong> y córtala en tiras finas.</li>\n<li>Corta los <strong>tomates</strong> por la mitad y colócalos hacia arriba en una bandeja de horno con papel de horno.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de respetar bien las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220 °C.</li>\n<li>Pela y pica el <strong>ajo.</strong></li>\n<li>Pela la <strong>chalota</strong> y córtala en tiras finas.</li>\n<li>Corta los <strong>tomates</strong> por la mitad y colócalos hacia arriba en una bandeja de horno con papel de horno.</li>\n</ul>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/68f8dd135578b4976ca226bc/step-5b705e00.jpg",
