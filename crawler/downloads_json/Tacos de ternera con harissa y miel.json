  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nRetira los extremos del pepino y córtalo en medias lunas finas.\nEn un bol, agrega el pepino, un chorrito de aceite y el vinagre.\nCorta el tomate a dados de 1 cm y reserva en un bol con un chorrito de aceite, sal y pimienta.\nAdereza el yogur griego con un chorrito de aceite, sal y pimienta.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Retira los extremos del <strong>pepino</strong> y córtalo en medias lunas finas.</li>\n<li>En un bol, agrega el <strong>pepino</strong>, un chorrito de <strong>aceite</strong> y el <strong>vinagre</strong>.</li>\n<li>Corta el <strong>tomate</strong> a dados de 1 cm y reserva en un bol con un chorrito de <strong>aceite, sal</strong> y <strong>pimienta</strong>.</li>\n<li>Adereza el <strong>yogur griego</strong> con un chorrito de <strong>aceite</strong>, <strong>sal</strong> y <strong>pimienta</strong>.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Retira los extremos del <strong>pepino</strong> y córtalo en medias lunas finas.</li>\n<li>En un bol, agrega el <strong>pepino</strong>, un chorrito de <strong>aceite</strong> y el <strong>vinagre</strong>.</li>\n<li>Corta el <strong>tomate</strong> a dados de 1 cm y reserva en un bol con un chorrito de <strong>aceite, sal</strong> y <strong>pimienta</strong>.</li>\n<li>Adereza el <strong>yogur griego</strong> con un chorrito de <strong>aceite</strong>, <strong>sal</strong> y <strong>pimienta</strong>.</li>\n</ul>",
      "ingredients": [],
