  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nPela la zanahoria y córtala por la mitad a lo largo. Corta en medias lunas de 1 cm.\nRetira los extremos del calabacín y córtalo por la mitad a lo largo. Corta en medias lunas de 1 cm.\nPela la cebolla y córtala en tiras de 2 cm. Separa con las manos las capas de la cebolla.\nCorta la patata en trozos de 2 cm.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Pela la <strong>zanahoria</strong> y córtala por la mitad a lo largo. Corta en medias lunas de 1 cm.</li>\n<li>Retira los extremos del <strong>calabacín</strong> y córtalo por la mitad a lo largo. Corta en medias lunas de 1 cm.</li>\n<li>Pela la <strong>cebolla</strong> y córtala en tiras de 2 cm. Separa con las manos las capas de la <strong>cebolla</strong>.</li>\n<li>Corta la <strong>patata</strong> en trozos de 2 cm.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Pela la <strong>zanahoria</strong> y córtala por la mitad a lo largo. Corta en medias lunas de 1 cm.</li>\n<li>Retira los extremos del <strong>calabacín</strong> y córtalo por la mitad a lo largo. Corta en medias lunas de 1 cm.</li>\n<li>Pela la <strong>cebolla</strong> y córtala en tiras de 2 cm. Separa con las manos las capas de la <strong>cebolla</strong>.</li>\n<li>Corta la <strong>patata</strong> en trozos de 2 cm.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "57e2674fb7e8697d4b305379"
      ],
      "timers": [],
