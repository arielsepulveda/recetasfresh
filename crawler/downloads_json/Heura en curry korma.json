  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nEn un bol, agrega las especias indias y la heura.\nRemueve para que quede bien cubierta.\nReserva hasta el paso 5.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>En un bol, agrega las <strong>especias indias</strong> y la <strong>heura</strong>.</li>\n<li>Remueve para que quede bien cubierta.</li>\n<li>Reserva hasta el paso 5.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>En un bol, agrega las <strong>especias indias</strong> y la <strong>heura</strong>.</li>\n<li>Remueve para que quede bien cubierta.</li>\n<li>Reserva hasta el paso 5.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "57e2674fb7e8697d4b305369"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/682c9b1fc4a648afcad036d2/step-4b4c1100.jpg",
