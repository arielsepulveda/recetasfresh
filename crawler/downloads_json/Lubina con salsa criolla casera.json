  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPela las patatas y la chirivía y corta en dados de 2 cm.\nEn una olla, agrega las patatas y la chirivía, cubre con agua y añade una pizca de sal.\nLleva a ebullición, luego, cocina a fuego medio 15-18 min o hasta que estén blandas.\n",
      "instructionsHTML": "<p><span style=\"color: rgb(0, 0, 0)\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</span></p>\n<ul>\n<li><span style=\"color: rgb(0, 0, 0)\">Pela las <strong>patatas</strong> y la <strong>chirivía</strong> y corta en dados de 2 cm.</span></li>\n<li><span style=\"color: rgb(0, 0, 0)\">En una olla, agrega las <strong>patatas</strong> y la <strong>chirivía,</strong> cubre con <strong>agua</strong> y añade una pizca de <strong>sal.</strong></span></li>\n<li><span style=\"color: rgb(0, 0, 0)\">Lleva a ebullición, luego, cocina a fuego medio 15-18 min o hasta que estén blandas.</span></li>\n</ul>",
      "instructionsMarkdown": "<p><span style=\"color: rgb(0, 0, 0)\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</span></p>\n<ul>\n<li><span style=\"color: rgb(0, 0, 0)\">Pela las <strong>patatas</strong> y la <strong>chirivía</strong> y corta en dados de 2 cm.</span></li>\n<li><span style=\"color: rgb(0, 0, 0)\">En una olla, agrega las <strong>patatas</strong> y la <strong>chirivía,</strong> cubre con <strong>agua</strong> y añade una pizca de <strong>sal.</strong></span></li>\n<li><span style=\"color: rgb(0, 0, 0)\">Lleva a ebullición, luego, cocina a fuego medio 15-18 min o hasta que estén blandas.</span></li>\n</ul>",
      "ingredients": [],
