    {
      "index": 2,
      "instructions": "\nPela la cebolla y córtala en daditos.\nPela y pica el ajo.\nPica la sobrasada.\n",
      "instructionsHTML": "<ul>\n<li>Pela la <strong>cebolla</strong> y córtala en daditos.</li>\n<li>Pela y pica el <strong>ajo</strong>.</li>\n<li>Pica la <strong>sobrasada</strong>.</li>\n</ul>",
      "instructionsMarkdown": "<ul>\n<li>Pela la <strong>cebolla</strong> y córtala en daditos.</li>\n<li>Pela y pica el <strong>ajo</strong>.</li>\n<li>Pica la <strong>sobrasada</strong>.</li>\n</ul>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/6849326d56532819dcc1a1ee/step-a5cc3710.jpg",
