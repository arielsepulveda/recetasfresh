  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nColoca el costillar de cerdo en una bandeja de horno con papel de horno.\nSalpimienta y hornea a media altura 10 min.\nMientras tanto, corta las patatas en rodajas de 1 cm.\n\nRECUERDA: Lávate las manos y los utensilios de cocina después de manipular carne cruda.",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Coloca el <strong>costillar de cerdo</strong> en una bandeja de horno con papel de horno.</li>\n<li><strong>Salpimienta</strong> y hornea a media altura 10 min.</li>\n<li>Mientras tanto, corta las <strong>patatas</strong> en rodajas de 1 cm.</li>\n</ul>\n<p>RECUERDA: Lávate las manos y los utensilios de cocina después de manipular carne cruda.</p>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Coloca el <strong>costillar de cerdo</strong> en una bandeja de horno con papel de horno.</li>\n<li><strong>Salpimienta</strong> y hornea a media altura 10 min.</li>\n<li>Mientras tanto, corta las <strong>patatas</strong> en rodajas de 1 cm.</li>\n</ul>\n<p>RECUERDA: Lávate las manos y los utensilios de cocina después de manipular carne cruda.</p>",
      "ingredients": [],
      "utensils": [
        "5e3ad24dfcf61c18c30ff522"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/67af1b4ee126ee27f0dcb833/step-22751c00.jpg",
