  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nEscurre los garbanzos, sécalos y colócalos en una bandeja de horno con papel de horno junto al ajo sin pelar.\nAdereza con el pimentón, el orégano, un chorrito de aceite, sal y pimienta.\nHornea a media altura 15 min, removiendo a mitad de cocción, hasta que se doren.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Escurre los <strong>garbanzos</strong>, sécalos<strong> </strong>y colócalos en una bandeja de horno con papel de horno junto al <strong>ajo</strong> sin pelar.</li>\n<li>Adereza con el <strong>pimentón,</strong> el <strong>orégano</strong>, un chorrito de <strong>aceite, sal</strong> y <strong>pimienta.</strong></li>\n<li>Hornea a media altura 15 min, removiendo a mitad de cocción, hasta que se doren.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Escurre los <strong>garbanzos</strong>, sécalos<strong> </strong>y colócalos en una bandeja de horno con papel de horno junto al <strong>ajo</strong> sin pelar.</li>\n<li>Adereza con el <strong>pimentón,</strong> el <strong>orégano</strong>, un chorrito de <strong>aceite, sal</strong> y <strong>pimienta.</strong></li>\n<li>Hornea a media altura 15 min, removiendo a mitad de cocción, hasta que se doren.</li>\n</ul>",
