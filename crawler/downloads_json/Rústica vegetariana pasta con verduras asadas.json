    {
      "index": 3,
      "instructions": "\nMientras se cocina la pasta, pela y pica el ajo.\nPica el cebollino.\nPica las nueces.\n",
      "instructionsHTML": "<ul>\n<li>Mientras se cocina la <strong>pasta</strong>, pela y pica el <strong>ajo</strong>.</li>\n<li>Pica el <strong>cebollino</strong>.</li>\n<li>Pica las <strong>nueces.</strong></li>\n</ul>",
      "instructionsMarkdown": "<ul>\n<li>Mientras se cocina la <strong>pasta</strong>, pela y pica el <strong>ajo</strong>.</li>\n<li>Pica el <strong>cebollino</strong>.</li>\n<li>Pica las <strong>nueces.</strong></li>\n</ul>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/6942e5680a853ea815820e47/step-2b8aae20.jpg",
