  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nCorta el tomate en cubos pequeños.\nPela la cebolla y corta en tiras finas.\nEn una ensaladera, mezcla el vinagre balsámico, un chorrito de aceite, sal y pimienta.\nAñade el tomate, la cebolla y el mezclum y mezcla.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Corta el <strong>tomate</strong> en cubos pequeños.</li>\n<li>Pela la <strong>cebolla</strong> y corta en tiras finas.</li>\n<li>En una ensaladera, mezcla el <strong>vinagre balsámico</strong>, un chorrito de <strong>aceite, sal</strong> y <strong>pimienta.</strong></li>\n<li>Añade el <strong>tomate,</strong> la <strong>cebolla</strong> y el <strong>mezclum</strong> y mezcla.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Corta el <strong>tomate</strong> en cubos pequeños.</li>\n<li>Pela la <strong>cebolla</strong> y corta en tiras finas.</li>\n<li>En una ensaladera, mezcla el <strong>vinagre balsámico</strong>, un chorrito de <strong>aceite, sal</strong> y <strong>pimienta.</strong></li>\n<li>Añade el <strong>tomate,</strong> la <strong>cebolla</strong> y el <strong>mezclum</strong> y mezcla.</li>\n</ul>",
      "ingredients": [],
