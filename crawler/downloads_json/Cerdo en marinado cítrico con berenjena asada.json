  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nRalla la piel del limón.\nRetira el tallo de la berenjena y córtala en dados de 1-2 cm.\nCorta el pimiento en cuadrados de 1-2 cm.\n",
      "instructionsHTML": "<p><span>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</span></p>\n<ul>\n<li><span>Ralla la piel del <strong>limón</strong>.</span></li>\n<li><span>Retira el tallo de la <strong>berenjena</strong> y córtala en dados de 1-2 cm.</span></li>\n<li><span>Corta el <strong>pimiento</strong> en cuadrados de 1-2 cm.</span></li>\n</ul>",
      "instructionsMarkdown": "<p><span>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</span></p>\n<ul>\n<li><span>Ralla la piel del <strong>limón</strong>.</span></li>\n<li><span>Retira el tallo de la <strong>berenjena</strong> y córtala en dados de 1-2 cm.</span></li>\n<li><span>Corta el <strong>pimiento</strong> en cuadrados de 1-2 cm.</span></li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "57e2674fb7e8697d4b305369",
        "57e2674fb7e8697d4b305385"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/688a78561cc5cea71280bbcd/step-adb48600.jpg",
