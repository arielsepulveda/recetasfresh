  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 200ºC con la opción de gratinar.\nEn una olla, agrega agua y sal y lleva a ebullición con la olla tapada.\nCuando el agua de la olla hierva, añade los rigatoni y cocina a fuego medio 10-12 min.\nEscurre cuando estén listos.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 200ºC con la opción de gratinar.</li>\n<li>En una olla, agrega <strong>agua</strong> y sal y lleva a ebullición con la olla tapada.</li>\n<li>Cuando el <strong>agua</strong> de la olla hierva, añade los <strong>rigatoni</strong> y cocina a fuego medio 10-12 min.</li>\n<li>Escurre cuando estén listos.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 200ºC con la opción de gratinar.</li>\n<li>En una olla, agrega <strong>agua</strong> y sal y lleva a ebullición con la olla tapada.</li>\n<li>Cuando el <strong>agua</strong> de la olla hierva, añade los <strong>rigatoni</strong> y cocina a fuego medio 10-12 min.</li>\n<li>Escurre cuando estén listos.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
