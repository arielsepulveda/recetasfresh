  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPica la coliflor en trozos pequeños.\nEn una olla, calienta un chorrito de aceite y la mantequilla a fuego medio-bajo.\nAñade la coliflor y rehoga 15-20 min, removiendo regularmente, hasta que se caramelice.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Pica la <strong>coliflor</strong> en trozos pequeños.</li>\n<li>En una olla, calienta un chorrito de <strong>aceite</strong> y la <strong>mantequilla</strong> a fuego medio-bajo.</li>\n<li>Añade la <strong>coliflor</strong> y rehoga 15-20 min, removiendo regularmente, hasta que se caramelice.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Pica la <strong>coliflor</strong> en trozos pequeños.</li>\n<li>En una olla, calienta un chorrito de <strong>aceite</strong> y la <strong>mantequilla</strong> a fuego medio-bajo.</li>\n<li>Añade la <strong>coliflor</strong> y rehoga 15-20 min, removiendo regularmente, hasta que se caramelice.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "57e2674fb7e8697d4b30537c"
      ],
      "timers": [],
      "images": [
