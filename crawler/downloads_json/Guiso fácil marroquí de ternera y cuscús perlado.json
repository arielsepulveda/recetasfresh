  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nCorta el pimiento en cubitos pequeños.\nPela la cebolla y corta en daditos.\nPela y pica el ajo.\nEn una olla, agrega un chorrito de aceite y el ajo. Calienta a fuego medio y cocina 1-2 min.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Corta el <strong>pimiento</strong> en cubitos pequeños.</li>\n<li>Pela la <strong>cebolla</strong> y corta en daditos.</li>\n<li>Pela y pica el <strong>ajo</strong>.</li>\n<li>En una olla, agrega un chorrito de <strong>aceite</strong> y el <strong>ajo</strong>. Calienta a fuego medio y cocina 1-2 min.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Corta el <strong>pimiento</strong> en cubitos pequeños.</li>\n<li>Pela la <strong>cebolla</strong> y corta en daditos.</li>\n<li>Pela y pica el <strong>ajo</strong>.</li>\n<li>En una olla, agrega un chorrito de <strong>aceite</strong> y el <strong>ajo</strong>. Calienta a fuego medio y cocina 1-2 min.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "57e2674fb7e8697d4b30537c"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/68d68a231d20e752a6dba8c9/step-fe36bc00.jpg",
