  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nCorta el calabacín por la mitad a lo largo. Con cortes diagonales, corta en medias lunas finas.\nEn una sartén, calienta un chorrito de aceite a fuego medio-alto. Agrega el calabacín, salpimienta y saltea 5-6 min, removiendo, hasta que quede dorado y tierno. Retira cuando esté listo.\nMientras tanto, pela y pica la cebolla y el ajo.\n",
      "instructionsHTML": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\"><span>Corta el <strong>calabacín</strong> por la mitad a lo largo. Con cortes diagonales, corta en medias lunas finas.</span></li>\n<li dir=\"ltr\">E<span>n una sartén, calient</span>a un chorrito de <strong>aceite</strong> a fuego medio-alto. Agrega el <strong>calabacín, salpimienta</strong> y saltea 5-6 min, removiendo, hasta que quede dorado y tierno. Retira cuando esté listo.</li>\n<li dir=\"ltr\">Mientras tanto, pela y pica la <strong>cebolla</strong> y el <strong>ajo</strong>.</li>\n</ul>",
      "instructionsMarkdown": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\"><span>Corta el <strong>calabacín</strong> por la mitad a lo largo. Con cortes diagonales, corta en medias lunas finas.</span></li>\n<li dir=\"ltr\">E<span>n una sartén, calient</span>a un chorrito de <strong>aceite</strong> a fuego medio-alto. Agrega el <strong>calabacín, salpimienta</strong> y saltea 5-6 min, removiendo, hasta que quede dorado y tierno. Retira cuando esté listo.</li>\n<li dir=\"ltr\">Mientras tanto, pela y pica la <strong>cebolla</strong> y el <strong>ajo</strong>.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
