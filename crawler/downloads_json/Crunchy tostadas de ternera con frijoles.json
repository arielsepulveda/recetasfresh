  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 200ºC.\nCorta el pimiento en dados de 0,5-1 cm.\nRalla la piel de la mitad de la lima y córtala en gajos.\nEscurre las judías rojas.\nPela la cebolleta y separa la parte verde. Pica ambas partes.\nReserva la parte verde hasta el emplatado.\n",
      "instructionsHTML": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\">Precalienta el horno a 200ºC.</li>\n<li dir=\"ltr\">Corta el <strong>pimiento</strong> en dados de 0,5-1 cm.</li>\n<li dir=\"ltr\">Ralla la piel de la mitad de la <strong>lima</strong> y córtala en gajos.</li>\n<li dir=\"ltr\">Escurre las <strong>judías rojas</strong>.</li>\n<li dir=\"ltr\">Pela la <strong>cebolleta</strong> y separa la parte verde. Pica ambas partes.</li>\n<li dir=\"ltr\">Reserva la parte verde hasta el emplatado.</li>\n</ul>",
      "instructionsMarkdown": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\">Precalienta el horno a 200ºC.</li>\n<li dir=\"ltr\">Corta el <strong>pimiento</strong> en dados de 0,5-1 cm.</li>\n<li dir=\"ltr\">Ralla la piel de la mitad de la <strong>lima</strong> y córtala en gajos.</li>\n<li dir=\"ltr\">Escurre las <strong>judías rojas</strong>.</li>\n<li dir=\"ltr\">Pela la <strong>cebolleta</strong> y separa la parte verde. Pica ambas partes.</li>\n<li dir=\"ltr\">Reserva la parte verde hasta el emplatado.</li>\n</ul>",
      "ingredients": [],
