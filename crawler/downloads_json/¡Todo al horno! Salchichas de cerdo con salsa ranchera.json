  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nCorta las patatas en bastones de 1 cm de grosor y 3-4 cm de largo.\nColócalos en un lado de una bandeja de horno con papel de horno y adereza con el sazonador barbacoa, un chorrito de aceite, el orégano, sal y pimienta. Remueve.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Corta las <strong>patatas</strong> en bastones de 1 cm de grosor y 3-4 cm de largo.</li>\n<li>Colócalos en un lado de una bandeja de horno con papel de horno y adereza con el <strong>sazonador barbacoa,</strong> un chorrito de <strong>aceite</strong>, el <strong>orégano</strong>, <strong>sal</strong> y <strong>pimienta</strong>. Remueve.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Corta las <strong>patatas</strong> en bastones de 1 cm de grosor y 3-4 cm de largo.</li>\n<li>Colócalos en un lado de una bandeja de horno con papel de horno y adereza con el <strong>sazonador barbacoa,</strong> un chorrito de <strong>aceite</strong>, el <strong>orégano</strong>, <strong>sal</strong> y <strong>pimienta</strong>. Remueve.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "5e3ad24dfcf61c18c30ff522"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/68d68a0ed232ff05cfc4a867/step-e4b86e00.jpg",
