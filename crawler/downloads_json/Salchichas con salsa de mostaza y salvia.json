    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220 ºC.\nCorta las patatas y el boniato en gajos de 1-2 cm de grosor.\n",
      "instructionsHTML": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\">Precalienta el horno a 220 ºC.</li>\n<li dir=\"ltr\">Corta las <strong>patatas</strong> y el <strong>boniato</strong> en gajos de 1-2 cm de grosor.</li>\n</ul>",
      "instructionsMarkdown": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\">Precalienta el horno a 220 ºC.</li>\n<li dir=\"ltr\">Corta las <strong>patatas</strong> y el <strong>boniato</strong> en gajos de 1-2 cm de grosor.</li>\n</ul>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/6776561fc7ac6d5384865e11/step-ff49f100.jpg",
