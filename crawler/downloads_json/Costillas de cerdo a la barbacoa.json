  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nCorta las patatas en rodajas de 1 cm.\nPela la zanahoria y retira el extremo. En cortes diagonales, divide la zanahoria en trozos de 2-3 cm.\nPela la cebolla y córtala en tiras de 2 cm.\n",
      "instructionsHTML": "<p><strong>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</strong></p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Corta las <strong>patatas</strong> en rodajas de 1 cm.</li>\n<li>Pela la <strong>zanahoria</strong> y retira el extremo. En cortes diagonales, divide la <strong>zanahoria</strong> en trozos de 2-3 cm.</li>\n<li>Pela la <strong>cebolla</strong> y córtala en tiras de 2 cm.</li>\n</ul>",
      "instructionsMarkdown": "<p><strong>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</strong></p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Corta las <strong>patatas</strong> en rodajas de 1 cm.</li>\n<li>Pela la <strong>zanahoria</strong> y retira el extremo. En cortes diagonales, divide la <strong>zanahoria</strong> en trozos de 2-3 cm.</li>\n<li>Pela la <strong>cebolla</strong> y córtala en tiras de 2 cm.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "57e2674fb7e8697d4b305379"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/68189411d15aa7b407b73b34/step-a07a5300.jpg",
