  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nLimpia las setas shiitake con un paño húmedo y córtalas en láminas finas.\nPela la cebollita francesa y cortala en cuartos.\nPela y ralla el ajo.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Limpia las <strong>setas shiitake</strong> con un paño húmedo y córtalas en láminas finas.</li>\n<li>Pela la<strong> cebollita francesa</strong> y cortala en cuartos.</li>\n<li>Pela y ralla el <strong>ajo</strong>.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Limpia las <strong>setas shiitake</strong> con un paño húmedo y córtalas en láminas finas.</li>\n<li>Pela la<strong> cebollita francesa</strong> y cortala en cuartos.</li>\n<li>Pela y ralla el <strong>ajo</strong>.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "57e2674fb7e8697d4b305385"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/68fb939587218af402500fbe/step-c2603f00.jpg",
