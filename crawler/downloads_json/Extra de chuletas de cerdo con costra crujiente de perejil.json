  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nRetira el tallo de la berenjena y córtala en dados de 1-2 cm. \nPela la cebolla y corta en tiras de 2 cm.\nCorta el pimiento en cuadrados de 2 cm.\nCorta el tomate por la mitad, luego, corta cada mitad en cuartos.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Retira el tallo de la <strong>berenjena</strong> y córtala en dados de 1-2 cm. </li>\n<li>Pela la <strong>cebolla</strong> y corta en tiras de 2 cm.</li>\n<li>Corta el <strong>pimiento</strong> en cuadrados de 2 cm.</li>\n<li>Corta el <strong>tomate</strong> por la mitad, luego, corta cada mitad en cuartos.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Retira el tallo de la <strong>berenjena</strong> y córtala en dados de 1-2 cm. </li>\n<li>Pela la <strong>cebolla</strong> y corta en tiras de 2 cm.</li>\n<li>Corta el <strong>pimiento</strong> en cuadrados de 2 cm.</li>\n<li>Corta el <strong>tomate</strong> por la mitad, luego, corta cada mitad en cuartos.</li>\n</ul>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/68fb939529be8924040c2efb/step-54b08400.jpg",
