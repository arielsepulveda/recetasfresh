  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! Pela y pica el ajo (ver cantidad en ingredientes). Pela la cebolla, divídela en dos y corta cada mitad en tiras de 2 cm. Pela la zanahoria y córtala por la mitad a lo largo. Luego, corta cada mitad en medias lunas de 0,5-1 cm. Corta los filetes de ternera en tiras finas de 1-2 cm de ancho y 3-4 cm de longitud. Salpimienta.",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! Pela y pica el <strong>ajo</strong> (ver cantidad en ingredientes). Pela la <strong>cebolla</strong>, divídela en dos y corta cada mitad en tiras de 2 cm. Pela la <strong>zanahoria</strong> y córtala por la mitad a lo largo. Luego, corta cada mitad en medias lunas de 0,5-1 cm. Corta los <strong>filetes de ternera</strong> en tiras finas de 1-2 cm de ancho y 3-4 cm de longitud. <strong>Salpimienta</strong>.</p>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! Pela y pica el <strong>ajo</strong> (ver cantidad en ingredientes). Pela la <strong>cebolla</strong>, divídela en dos y corta cada mitad en tiras de 2 cm. Pela la <strong>zanahoria</strong> y córtala por la mitad a lo largo. Luego, corta cada mitad en medias lunas de 0,5-1 cm. Corta los <strong>filetes de ternera</strong> en tiras finas de 1-2 cm de ancho y 3-4 cm de longitud. <strong>Salpimienta</strong>.</p>",
      "ingredients": [],
