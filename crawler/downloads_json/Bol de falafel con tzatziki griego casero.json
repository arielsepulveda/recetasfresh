  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nEn un cazo, agrega el agua, sal y la quinoa.\nLleva a ebullición, luego, cocina a fuego medio-bajo 12 min, con el cazo tapado.\nUna vez listo, remueve y deja reposar con la tapa puesta.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>En un cazo, agrega el <strong>agua</strong>, <strong>sal</strong> y la <strong>quinoa</strong>.</li>\n<li>Lleva a ebullición, luego, cocina a fuego medio-bajo 12 min, con el cazo tapado.</li>\n<li>Una vez listo, remueve y deja reposar con la tapa puesta.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>En un cazo, agrega el <strong>agua</strong>, <strong>sal</strong> y la <strong>quinoa</strong>.</li>\n<li>Lleva a ebullición, luego, cocina a fuego medio-bajo 12 min, con el cazo tapado.</li>\n<li>Una vez listo, remueve y deja reposar con la tapa puesta.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "623c805661a1b9d0034f9066",
