  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nCorta las patatas en gajos de 1-2 cm de grosor.\nCorta el pimiento en tiras finas.\nColóca los vegetales en una bandeja de horno con papel de horno y agrega un chorrito de aceite, sal y pimienta.\nMezcla y hornea 20-25 min o hasta que estén doradas. Remueve a mitad de cocción.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Corta las <strong>patatas</strong> en gajos de 1-2 cm de grosor.</li>\n<li>Corta el <strong>pimiento</strong> en tiras finas.</li>\n<li>Colóca los <strong>vegetales</strong> en una bandeja de horno con papel de horno y agrega un chorrito de <strong>aceite, sal</strong> y <strong>pimienta</strong>.</li>\n<li>Mezcla y hornea 20-25 min o hasta que estén doradas. Remueve a mitad de cocción.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Corta las <strong>patatas</strong> en gajos de 1-2 cm de grosor.</li>\n<li>Corta el <strong>pimiento</strong> en tiras finas.</li>\n<li>Colóca los <strong>vegetales</strong> en una bandeja de horno con papel de horno y agrega un chorrito de <strong>aceite, sal</strong> y <strong>pimienta</strong>.</li>\n<li>Mezcla y hornea 20-25 min o hasta que estén doradas. Remueve a mitad de cocción.</li>\n</ul>",
      "ingredients": [],
