    {
      "index": 6,
      "instructions": "\nAgrega la escalivada de verduras sobre los panes al tomillo y sirve en platos.\nColoca la ensalada a un lado como acompañamiento.\n",
      "instructionsHTML": "<ul>\n<li>Agrega la <strong>escalivada</strong> de <strong>verduras</strong> sobre los <strong>panes al tomillo</strong> y sirve en platos.</li>\n<li>Coloca la <strong>ensalada</strong> a un lado como acompañamiento.</li>\n</ul>",
      "instructionsMarkdown": "<ul>\n<li>Agrega la <strong>escalivada</strong> de <strong>verduras</strong> sobre los <strong>panes al tomillo</strong> y sirve en platos.</li>\n<li>Coloca la <strong>ensalada</strong> a un lado como acompañamiento.</li>\n</ul>",
