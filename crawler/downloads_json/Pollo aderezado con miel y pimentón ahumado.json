  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nCorta el tomate en cubos pequeños.\nCorta la mozzarella en rodajas de 0,5-1 cm de grosor y colócala en un colador.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Corta el <strong>tomate</strong> en cubos pequeños.</li>\n<li>Corta la <strong>mozzarella</strong> en rodajas de 0,5-1 cm de grosor y colócala en un colador.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Corta el <strong>tomate</strong> en cubos pequeños.</li>\n<li>Corta la <strong>mozzarella</strong> en rodajas de 0,5-1 cm de grosor y colócala en un colador.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "5e3ad24efcf61c18c30ff538"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/6849324856532819dcc1a16a/step-798b7e00.jpg",
