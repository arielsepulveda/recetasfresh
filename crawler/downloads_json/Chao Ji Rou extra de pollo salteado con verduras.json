  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nLlena un cazo con el agua, la leche de coco y añade el arroz y sal.\nCuando hierva, Cocina a fuego medio 11-13 min y remueve.\nUna vez cocinado, remueve el arroz y resérvalo en el cazo tapado\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Llena un cazo con el <strong>agua</strong>, la <strong>leche de coco</strong> y añade el <strong>arroz</strong> y <strong>sal</strong>.</li>\n<li>Cuando hierva, Cocina a fuego medio 11-13 min y remueve.</li>\n<li>Una vez cocinado, remueve el <strong>arroz</strong> y resérvalo en el cazo tapado</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Llena un cazo con el <strong>agua</strong>, la <strong>leche de coco</strong> y añade el <strong>arroz</strong> y <strong>sal</strong>.</li>\n<li>Cuando hierva, Cocina a fuego medio 11-13 min y remueve.</li>\n<li>Una vez cocinado, remueve el <strong>arroz</strong> y resérvalo en el cazo tapado</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "623c805661a1b9d0034f9066",
        "5e3ad24efcf61c18c30ff538",
        "6351278800ba8b8f1c369774"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/6942e55735efa043add8c65f/step-de344500.jpg",
