  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! En una olla, agrega abundante agua y sal y lleva a ebullición. Pela la cebolla, divídela en dos y corta una mitad (doble para 4p) en daditos. Limpia los champiñones con un paño húmedo. Retira y desecha el extremo del pie de los champiñones. Luego, córtalos en láminas finas. Pela y pica el ajo (ver cantidad en ingredientes).",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! En una olla, agrega abundante <strong>agua</strong> y <strong>sal</strong> y lleva a ebullición. Pela la <strong>cebolla,</strong> divídela en dos y corta una mitad (doble para 4p) en daditos. Limpia los <strong>champiñones</strong> con un paño húmedo. Retira y desecha el extremo del pie de los <strong>champiñones</strong>. Luego, córtalos en láminas finas. Pela y pica el <strong>ajo</strong> (ver cantidad en ingredientes).</p>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! En una olla, agrega abundante <strong>agua</strong> y <strong>sal</strong> y lleva a ebullición. Pela la <strong>cebolla,</strong> divídela en dos y corta una mitad (doble para 4p) en daditos. Limpia los <strong>champiñones</strong> con un paño húmedo. Retira y desecha el extremo del pie de los <strong>champiñones</strong>. Luego, córtalos en láminas finas. Pela y pica el <strong>ajo</strong> (ver cantidad en ingredientes).</p>",
      "ingredients": [],
