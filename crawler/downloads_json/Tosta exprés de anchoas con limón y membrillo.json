  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nEn un bol, añade el queso crema, la créme fraîche, sal y pimienta al gusto.\nMezcla con varillas hasta conseguir una textura cremosa.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>En un bol, añade el <strong>queso crema</strong>, la <strong>créme fraîche</strong>, <strong>sal</strong> y <strong>pimienta</strong> al gusto.</li>\n<li>Mezcla con varillas hasta conseguir una textura cremosa.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>En un bol, añade el <strong>queso crema</strong>, la <strong>créme fraîche</strong>, <strong>sal</strong> y <strong>pimienta</strong> al gusto.</li>\n<li>Mezcla con varillas hasta conseguir una textura cremosa.</li>\n</ul>",
      "ingredients": [],
