  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nPela la zanahoria y córtala por la mitad a lo largo. Corta en bastones de 1 cm de grosor.\nEscurre los garbanzos.\nColoca la mitad de los garbanzos en la mitad una bandeja de horno con papel de horno y adereza con un chorrito de aceite, sal y pimienta.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Pela la <strong>zanahoria</strong> y córtala por la mitad a lo largo. Corta en bastones de 1 cm de grosor.</li>\n<li>Escurre los <strong>garbanzos</strong>.</li>\n<li>Coloca la mitad de los <strong>garbanzos</strong> en la mitad una bandeja de horno con papel de horno y adereza con un chorrito de <strong>aceite, sal</strong> y <strong>pimienta.</strong></li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Pela la <strong>zanahoria</strong> y córtala por la mitad a lo largo. Corta en bastones de 1 cm de grosor.</li>\n<li>Escurre los <strong>garbanzos</strong>.</li>\n<li>Coloca la mitad de los <strong>garbanzos</strong> en la mitad una bandeja de horno con papel de horno y adereza con un chorrito de <strong>aceite, sal</strong> y <strong>pimienta.</strong></li>\n</ul>",
      "ingredients": [],
