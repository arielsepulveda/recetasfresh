  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nLlena un cazo con el agua, añade el arroz y sal y lleva a ebullición con el cazo tapado.\nCuando hierva, cocina a fuego medio-bajo 11-13 min, removiendo.\nLuego, retira del fuego y reserva en el cazo tapado.\n",
      "instructionsHTML": "<p><strong>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</strong></p>\n<ul>\n<li>Llena un cazo con el <strong>agua</strong>, añade el <strong>arroz</strong> y <strong>sal</strong> y lleva a ebullición con el cazo tapado.</li>\n<li>Cuando hierva, cocina a fuego medio-bajo 11-13 min, removiendo.</li>\n<li>Luego, retira del fuego y reserva en el cazo tapado.</li>\n</ul>",
      "instructionsMarkdown": "<p><strong>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</strong></p>\n<ul>\n<li>Llena un cazo con el <strong>agua</strong>, añade el <strong>arroz</strong> y <strong>sal</strong> y lleva a ebullición con el cazo tapado.</li>\n<li>Cuando hierva, cocina a fuego medio-bajo 11-13 min, removiendo.</li>\n<li>Luego, retira del fuego y reserva en el cazo tapado.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "623c805661a1b9d0034f9066",
        "5e3ad24efcf61c18c30ff538",
        "6351278800ba8b8f1c369774"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/682c9af27fe6dd267e29d761/step-fff7bf00.jpg",
