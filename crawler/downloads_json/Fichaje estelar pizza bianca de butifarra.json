  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nCon un cuchillo, haz un corte en la piel de la butifarra y retírala, quedándote con la carne.\nCorta los tomates cherry por la mitad.\n\nRECUERDA: Lávate las manos y los utensilios de cocina después de manipular carne cruda.",
      "instructionsHTML": "<p><strong>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</strong></p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Con un cuchillo, haz un corte en la piel de la <strong>butifarra</strong> y retírala, quedándote con la carne.</li>\n<li>Corta los <strong>tomates cherry</strong> por la mitad.</li>\n</ul>\n<p>RECUERDA: Lávate las manos y los utensilios de cocina después de manipular carne cruda.</p>",
      "instructionsMarkdown": "<p><strong>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</strong></p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Con un cuchillo, haz un corte en la piel de la <strong>butifarra</strong> y retírala, quedándote con la carne.</li>\n<li>Corta los <strong>tomates cherry</strong> por la mitad.</li>\n</ul>\n<p>RECUERDA: Lávate las manos y los utensilios de cocina después de manipular carne cruda.</p>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
