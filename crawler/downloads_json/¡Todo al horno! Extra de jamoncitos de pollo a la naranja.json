  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nPela la cebolla y córtala en tiras de 2 cm.\nPela la manzana y córtala en dados de 2 cm.\nCorta las patatas en dados de 1-2 cm.\nRetira el extremo de la zanahoria y deséchalo. En cortes diagonales, divide la zanahoria en trozos de 1-2 cm.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Pela la <strong>cebolla</strong> y córtala en tiras de 2 cm.</li>\n<li>Pela la <strong>manzana</strong> y córtala en dados de 2 cm.</li>\n<li>Corta las <strong>patatas</strong> en dados de 1-2 cm.</li>\n<li>Retira el extremo de la <strong>zanahoria </strong>y deséchalo. En cortes diagonales, divide la <strong>zanahoria </strong>en trozos de 1-2 cm.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Pela la <strong>cebolla</strong> y córtala en tiras de 2 cm.</li>\n<li>Pela la <strong>manzana</strong> y córtala en dados de 2 cm.</li>\n<li>Corta las <strong>patatas</strong> en dados de 1-2 cm.</li>\n<li>Retira el extremo de la <strong>zanahoria </strong>y deséchalo. En cortes diagonales, divide la <strong>zanahoria </strong>en trozos de 1-2 cm.</li>\n</ul>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
