  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nCorta el pimiento en tiras finas de 0,5-1 cm de grosor.\nPela la cebolla y córtala en tiras finitas.\nPela y corta las patatas en rodajas de 0,5-1 cm de grosor.\n",
      "instructionsHTML": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\">Precalienta el horno a 220ºC.</li>\n<li dir=\"ltr\">Corta el <strong>pimiento</strong> en tiras finas de 0,5-1 cm de grosor.</li>\n<li dir=\"ltr\">Pela la <strong>cebolla</strong> y córtala en tiras finitas.</li>\n<li dir=\"ltr\">Pela y corta las <strong>patatas</strong> en rodajas de 0,5-1 cm de grosor.</li>\n</ul>",
      "instructionsMarkdown": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\">Precalienta el horno a 220ºC.</li>\n<li dir=\"ltr\">Corta el <strong>pimiento</strong> en tiras finas de 0,5-1 cm de grosor.</li>\n<li dir=\"ltr\">Pela la <strong>cebolla</strong> y córtala en tiras finitas.</li>\n<li dir=\"ltr\">Pela y corta las <strong>patatas</strong> en rodajas de 0,5-1 cm de grosor.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "57e2674fb7e8697d4b305379"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/674d6fd9f02f84674c8051bd/step-79833a00.jpg",
