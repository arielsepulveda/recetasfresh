  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! Precalienta el horno a 220ºC en la opción de gratinar. Corta el rulo de queso de cabra en rodajas de 1 cm, de forma que queden 3 rodajas por persona. Coloca el queso en una bandeja de horno con papel de horno y agrega encima el azúcar (ver cantidad en ingredientes). Hornea el queso en el estante superior durante 8-10 min o hasta que se caramelize.",
      "instructionsHTML": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! Precalienta el horno a 220ºC en la opción de gratinar. Corta el <strong>rulo de queso de cabra</strong> en rodajas de 1 cm, de forma que queden 3 rodajas por persona. Coloca el <strong>queso</strong> en una bandeja de horno con papel de horno y agrega encima el <strong>azúcar</strong> (ver cantidad en ingredientes). Hornea el <strong>queso</strong> en el estante superior durante 8-10 min o hasta que se caramelize.</p>",
      "instructionsMarkdown": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! Precalienta el horno a 220ºC en la opción de gratinar. Corta el <strong>rulo de queso de cabra</strong> en rodajas de 1 cm, de forma que queden 3 rodajas por persona. Coloca el <strong>queso</strong> en una bandeja de horno con papel de horno y agrega encima el <strong>azúcar</strong> (ver cantidad en ingredientes). Hornea el <strong>queso</strong> en el estante superior durante 8-10 min o hasta que se caramelize.</p>",
      "ingredients": [],
      "utensils": [
        "5e3ad24dfcf61c18c30ff522"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/64788ace904daffe76f26a25/step-1c026600.jpg",
