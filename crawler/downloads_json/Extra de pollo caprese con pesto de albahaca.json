  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nRealiza 3 cortes en la parte de arriba de la pechuga de pollo, sin llegar hasta el final, de manera que puedas introducir los ingredientes.\nCorta la mitad del tomate el medias lunas finas y sécalo.\nCorta el tomate restante en dados pequeños.\nSalpimienta el pollo.\n\nRECUERDA: Lávate las manos y los utensilios de cocina después de manipular carne cruda.",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Realiza 3 cortes en la parte de arriba de la <strong>pechuga de pollo</strong>, sin llegar hasta el final, de manera que puedas introducir los ingredientes.</li>\n<li>Corta la mitad del <strong>tomate</strong> el medias lunas finas y sécalo.</li>\n<li>Corta el <strong>tomate</strong> restante en dados pequeños.</li>\n<li><strong>Salpimienta</strong> el <strong>pollo</strong>.</li>\n</ul>\n<p>RECUERDA: Lávate las manos y los utensilios de cocina después de manipular carne cruda.</p>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Realiza 3 cortes en la parte de arriba de la <strong>pechuga de pollo</strong>, sin llegar hasta el final, de manera que puedas introducir los ingredientes.</li>\n<li>Corta la mitad del <strong>tomate</strong> el medias lunas finas y sécalo.</li>\n<li>Corta el <strong>tomate</strong> restante en dados pequeños.</li>\n<li><strong>Salpimienta</strong> el <strong>pollo</strong>.</li>\n</ul>\n<p>RECUERDA: Lávate las manos y los utensilios de cocina después de manipular carne cruda.</p>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/68fb939729be8924040c2f02/step-12d53f00.jpg",
