  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nPela la cebolla y corta en tiras de 2 cm.\nCorta los tomates cherry por la mitad.\nRetira el tallo de la berenjena y córtala en dados de 1-2 cm.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Pela la <strong>cebolla</strong> y corta en tiras de 2 cm.</li>\n<li>Corta los <strong>tomates cherry</strong> por la mitad.</li>\n<li>Retira el tallo de la <strong>berenjena</strong> y córtala en dados de 1-2 cm.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Pela la <strong>cebolla</strong> y corta en tiras de 2 cm.</li>\n<li>Corta los <strong>tomates cherry</strong> por la mitad.</li>\n<li>Retira el tallo de la <strong>berenjena</strong> y córtala en dados de 1-2 cm.</li>\n</ul>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/688a786e9643892dc8fa15d6/step-f1d47b00.jpg",
