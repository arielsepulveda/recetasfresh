  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nCorta las patatas en gajos de 1-2 cm de grosor.\nEn un bol, mezcla las patatas, las especias tailandesas, la harina, un chorrito de aceite, sal y pimienta.\nColoca la patata en una bandeja de horno con papel de horno y hornea a media altura 20-25 min o hasta que quede dorada y tierna. Da la vuelta a mitad de cocción.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Corta las <strong>patatas</strong> en gajos de 1-2 cm de grosor.</li>\n<li>En un bol, mezcla las <strong>patatas,</strong> las <strong>especias tailandesas,</strong> la <strong>harina,</strong> un chorrito de <strong>aceite</strong>, <strong>sal</strong> y <strong>pimienta</strong>.</li>\n<li>Coloca la <strong>patata</strong> en una bandeja de horno con papel de horno y hornea a media altura 20-25 min o hasta que quede dorada y tierna. Da la vuelta a mitad de cocción.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Corta las <strong>patatas</strong> en gajos de 1-2 cm de grosor.</li>\n<li>En un bol, mezcla las <strong>patatas,</strong> las <strong>especias tailandesas,</strong> la <strong>harina,</strong> un chorrito de <strong>aceite</strong>, <strong>sal</strong> y <strong>pimienta</strong>.</li>\n<li>Coloca la <strong>patata</strong> en una bandeja de horno con papel de horno y hornea a media altura 20-25 min o hasta que quede dorada y tierna. Da la vuelta a mitad de cocción.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "57e2674fb7e8697d4b305369",
