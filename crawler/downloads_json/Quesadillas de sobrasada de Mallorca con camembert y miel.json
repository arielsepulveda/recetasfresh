    {
      "index": 2,
      "instructions": "\nCorta el queso camembert en tiras finas.\nDesmenuza la sobrasada.\n",
      "instructionsHTML": "<ul>\n<li>Corta el <strong>queso camembert</strong> en tiras finas.</li>\n<li>Desmenuza la <strong>sobrasada.</strong></li>\n</ul>",
      "instructionsMarkdown": "<ul>\n<li>Corta el <strong>queso camembert</strong> en tiras finas.</li>\n<li>Desmenuza la <strong>sobrasada.</strong></li>\n</ul>",
      "ingredients": [],
