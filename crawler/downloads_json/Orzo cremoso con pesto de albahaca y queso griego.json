  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nCalienta una olla a fuego medio-alto sin aceite y tuesta las semillas de calabaza 1-2 min, hasta que se doren. Retira de la olla.\nPela la cebolla y córtala en daditos.\nPela y pica el ajo.\n",
      "instructionsHTML": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\">Calienta una olla a fuego medio-alto sin aceite y tuesta las <strong>semillas de calabaza</strong> 1-2 min, hasta que se doren. Retira de la olla.</li>\n<li dir=\"ltr\">Pela la <strong>cebolla</strong> y córtala en daditos.</li>\n<li>Pela y pica el <strong>ajo</strong>.</li>\n</ul>",
      "instructionsMarkdown": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\">Calienta una olla a fuego medio-alto sin aceite y tuesta las <strong>semillas de calabaza</strong> 1-2 min, hasta que se doren. Retira de la olla.</li>\n<li dir=\"ltr\">Pela la <strong>cebolla</strong> y córtala en daditos.</li>\n<li>Pela y pica el <strong>ajo</strong>.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "57e2674fb7e8697d4b30537c"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/684932549f34f686e2db876f/step-4545d600.jpg",
