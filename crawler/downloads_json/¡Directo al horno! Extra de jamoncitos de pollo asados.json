    {
      "index": 2,
      "instructions": "\nCorta el pimiento en dados de 0,5 cm.\nPela la cebolla y córtala en tiras finas.\n",
      "instructionsHTML": "<ul>\n<li>Corta el <strong>pimiento</strong> en dados de 0,5 cm.</li>\n<li>Pela la <strong>cebolla</strong> y córtala en tiras finas.</li>\n</ul>",
      "instructionsMarkdown": "<ul>\n<li>Corta el <strong>pimiento</strong> en dados de 0,5 cm.</li>\n<li>Pela la <strong>cebolla</strong> y córtala en tiras finas.</li>\n</ul>",
      "ingredients": [],
