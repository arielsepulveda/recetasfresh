  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nCorta el boniato en dados de 2 cm.\nRetira el tallo de la berenjena y córtala en dados de 1-2 cm.\nPela la cebolla y corta cada mitad en tiras de 2 cm.\nRetira los extremos del calabacín y córtalo por la mitad a lo largo. Corta en medias lunas de 0,5-1 cm.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Corta el <strong>boniato</strong> en dados de 2 cm.</li>\n<li>Retira el tallo de la <strong>berenjena</strong> y córtala en dados de 1-2 cm.</li>\n<li>Pela la <strong>cebolla</strong> y corta cada mitad en tiras de 2 cm.</li>\n<li>Retira los extremos del <strong>calabacín</strong> y córtalo por la mitad a lo largo. Corta en medias lunas de 0,5-1 cm.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Corta el <strong>boniato</strong> en dados de 2 cm.</li>\n<li>Retira el tallo de la <strong>berenjena</strong> y córtala en dados de 1-2 cm.</li>\n<li>Pela la <strong>cebolla</strong> y corta cada mitad en tiras de 2 cm.</li>\n<li>Retira los extremos del <strong>calabacín</strong> y córtalo por la mitad a lo largo. Corta en medias lunas de 0,5-1 cm.</li>\n</ul>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/688b7442b6ffa7a20c3c60a4/step-046a2500.jpg",
