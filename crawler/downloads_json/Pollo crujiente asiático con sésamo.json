    {
      "index": 6,
      "instructions": "\nSirve el arroz con verduras en la base de los platos.\nAñade el pollo frito encima.\n",
      "instructionsHTML": "<ul>\n<li>Sirve el <strong>arroz</strong> con <strong>verduras</strong> en la base de los platos.</li>\n<li>Añade el <strong>pollo frito</strong> encima.</li>\n</ul>",
      "instructionsMarkdown": "<ul>\n<li>Sirve el <strong>arroz</strong> con <strong>verduras</strong> en la base de los platos.</li>\n<li>Añade el <strong>pollo frito</strong> encima.</li>\n</ul>",
