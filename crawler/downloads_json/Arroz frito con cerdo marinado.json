    {
      "index": 6,
      "instructions": "\nPica los cacahuetes.\nSirve el arroz con cerdo marinado y tortilla en platos y cubre con cacahuetes al gusto.\n",
      "instructionsHTML": "<ul>\n<li dir=\"ltr\">Pica los <strong>cacahuetes.</strong></li>\n<li dir=\"ltr\">Sirve el <strong>arroz</strong> con <strong>cerdo</strong> marinado y <strong>tortilla</strong> en platos y cubre con <strong>cacahuetes</strong> al gusto.</li>\n</ul>",
