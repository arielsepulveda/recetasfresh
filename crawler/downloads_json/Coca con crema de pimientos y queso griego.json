  "steps": [
    {
      "index": 1,
      "instructions": "\n\n¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! Precalienta el horno a 220ºC. Pela la cebolla, divídela en dos y córtala en tiras finas. Corta los pimientos por la mitad y quítales las semillas. Luego, córtalos en dados de 1-2 cm.\n\n",
      "instructionsHTML": "<p><div dir=&quot;ltr&quot;>\n<div>\n<div id=&quot;waffle-rich-text-editor&quot; dir=&quot;ltr&quot;>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! Precalienta el horno a 220ºC. Pela la <strong>cebolla</strong>, divídela en dos y córtala en tiras finas. Corta los <strong>pimientos</strong> por la mitad<strong> </strong>y quítales las semillas. Luego, córtalos en dados de 1-2 cm.</div>\n</div>\n</div></p>",
      "instructionsMarkdown": "<div dir=\"ltr\">\n<div>\n<div id=\"waffle-rich-text-editor\" dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! Precalienta el horno a 220ºC. Pela la <strong>cebolla</strong>, divídela en dos y córtala en tiras finas. Corta los <strong>pimientos</strong> por la mitad<strong> </strong>y quítales las semillas. Luego, córtalos en dados de 1-2 cm.</div>\n</div>\n</div>",
      "ingredients": [],
