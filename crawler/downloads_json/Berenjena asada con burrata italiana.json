  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nCorta la berenjena desde la parte superior en 4 tiras, de manera que queden unidas al tallo.\nColoca las berenjenas en una bandeja de horno con papel de horno.\nEn un bol, mezcla un chorrito de aceite y la mitad de las especias mediterráneas.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Corta la <strong>berenjena</strong> desde la parte superior en 4 tiras, de manera que queden unidas al tallo.</li>\n<li>Coloca las <strong>berenjenas</strong> en una bandeja de horno con papel de horno.</li>\n<li>En un bol, mezcla un chorrito de <strong>aceite</strong> y la mitad de las <strong>especias mediterráneas</strong>.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Corta la <strong>berenjena</strong> desde la parte superior en 4 tiras, de manera que queden unidas al tallo.</li>\n<li>Coloca las <strong>berenjenas</strong> en una bandeja de horno con papel de horno.</li>\n<li>En un bol, mezcla un chorrito de <strong>aceite</strong> y la mitad de las <strong>especias mediterráneas</strong>.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "5e3ad24dfcf61c18c30ff522",
        "57e2674fb7e8697d4b305380"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/68fb9392493c3115e37226f9/step-7e484d00.jpg",
