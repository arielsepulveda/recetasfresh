  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPela y pica el ajo.\nPela la cebolla y corta en daditos.\nRetira las raíces y el extremo verde del puerro y deséchalos. Córtalo por la mitad a lo largo, luego, corta en medias lunas finas.\nCorta la manzana en dados de 1 cm.\n",
      "instructionsHTML": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\">Pela y pica el <strong>ajo</strong>.</li>\n<li dir=\"ltr\">Pela la <strong>cebolla</strong> y corta en daditos.</li>\n<li dir=\"ltr\">Retira las raíces y el extremo verde del <strong>puerro</strong> y deséchalos. Córtalo por la mitad a lo largo, luego, corta en medias lunas finas.</li>\n<li dir=\"ltr\">Corta la <strong>manzana</strong> en dados de 1 cm.</li>\n</ul>",
      "instructionsMarkdown": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\">Pela y pica el <strong>ajo</strong>.</li>\n<li dir=\"ltr\">Pela la <strong>cebolla</strong> y corta en daditos.</li>\n<li dir=\"ltr\">Retira las raíces y el extremo verde del <strong>puerro</strong> y deséchalos. Córtalo por la mitad a lo largo, luego, corta en medias lunas finas.</li>\n<li dir=\"ltr\">Corta la <strong>manzana</strong> en dados de 1 cm.</li>\n</ul>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/6849325156532819dcc1a195/step-bfc39200.jpg",
          "path": "/6849325156532819dcc1a195/step-bfc39200.jpg",
          "caption": "Prepara las verduras",
