  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nCorta las patatas en gajos de 1-2 cm de grosor.\nColócalos en una bandeja de horno con papel de horno y agrega un chorrito de aceite, el tomillo seco, sal y pimienta.\nMezcla y hornea a media altura 20-25 min o hasta que estén dorados. Dales la vuelta a mitad de cocción.\n",
      "instructionsHTML": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\">Precalienta el horno a 220ºC.</li>\n<li dir=\"ltr\">Corta las <strong>patatas</strong> en gajos de 1-2 cm de grosor.</li>\n<li dir=\"ltr\">Colócalos en una bandeja de horno con papel de horno y agrega un chorrito de <strong>aceite</strong>, el <strong>tomillo seco, sal</strong> y <strong>pimienta</strong>.</li>\n<li dir=\"ltr\">Mezcla y hornea a media altura 20-25 min o hasta que estén dorados. Dales la vuelta a mitad de cocción.</li>\n</ul>",
      "instructionsMarkdown": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\">Precalienta el horno a 220ºC.</li>\n<li dir=\"ltr\">Corta las <strong>patatas</strong> en gajos de 1-2 cm de grosor.</li>\n<li dir=\"ltr\">Colócalos en una bandeja de horno con papel de horno y agrega un chorrito de <strong>aceite</strong>, el <strong>tomillo seco, sal</strong> y <strong>pimienta</strong>.</li>\n<li dir=\"ltr\">Mezcla y hornea a media altura 20-25 min o hasta que estén dorados. Dales la vuelta a mitad de cocción.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "5e3ad24dfcf61c18c30ff522"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/696f9b6f84d22895b02c3120/step-e5091100.jpg",
