  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! Precalienta el horno a 220ºC. Corta las patatas por la mitad a lo largo, luego, apoya la patata por la parte plana y corta en gajos de 1-2 cm de grosor. Pela la cebolla, divídela en dos y córtala en tiras finas.",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! Precalienta el horno a 220ºC. Corta las <strong>patatas</strong> por la mitad a lo largo, luego, apoya la <strong>patata</strong> por la parte plana y corta en gajos de 1-2 cm de grosor. Pela la <strong>cebolla,</strong> divídela en dos y córtala en tiras finas.</p>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! Precalienta el horno a 220ºC. Corta las <strong>patatas</strong> por la mitad a lo largo, luego, apoya la <strong>patata</strong> por la parte plana y corta en gajos de 1-2 cm de grosor. Pela la <strong>cebolla,</strong> divídela en dos y córtala en tiras finas.</p>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
