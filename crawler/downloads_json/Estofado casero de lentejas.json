  "steps": [
    {
      "index": 1,
      "instructions": "Pela y pica finamente el ajo (ver cantidad en ingredientes). Pela la cebolla, divídela en dos y corta una mitad (doble para 4p) en daditos pequeños. Corta las patatas en dados de 2-3 cm.",
      "instructionsHTML": "<p>Pela y pica finamente el <strong>ajo</strong> (ver cantidad en ingredientes). Pela la <strong>cebolla</strong>, divídela en dos y corta una mitad (doble para 4p) en daditos pequeños. Corta las <strong>patatas</strong> en dados de 2-3 cm.</p>",
      "instructionsMarkdown": "<p>Pela y pica finamente el <strong>ajo</strong> (ver cantidad en ingredientes). Pela la <strong>cebolla</strong>, divídela en dos y corta una mitad (doble para 4p) en daditos pequeños. Corta las <strong>patatas</strong> en dados de 2-3 cm.</p>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
      "images": [
