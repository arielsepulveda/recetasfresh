  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nEn un bol grande, agrega el pollo, la mitad del sazonador barbacoa, un chorrito de aceite, sal y pimienta.\nMezcla y reserva hasta el paso 4.\n\nRECUERDA: Lávate las manos y los utensilios de cocina después de manipular carne cruda.",
      "instructionsHTML": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\">Precalienta el horno a 220ºC.</li>\n<li dir=\"ltr\">En un bol grande, agrega el<strong> pollo</strong>, la mitad del <strong>sazonador barbacoa, </strong>un chorrito de<strong> aceite</strong>, <strong>sal</strong> y <strong>pimienta</strong>.</li>\n<li dir=\"ltr\">Mezcla y reserva hasta el paso 4.</li>\n</ul>\n<p dir=\"ltr\">RECUERDA: Lávate las manos y los utensilios de cocina después de manipular carne cruda.</p>",
      "instructionsMarkdown": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\">Precalienta el horno a 220ºC.</li>\n<li dir=\"ltr\">En un bol grande, agrega el<strong> pollo</strong>, la mitad del <strong>sazonador barbacoa, </strong>un chorrito de<strong> aceite</strong>, <strong>sal</strong> y <strong>pimienta</strong>.</li>\n<li dir=\"ltr\">Mezcla y reserva hasta el paso 4.</li>\n</ul>\n<p dir=\"ltr\">RECUERDA: Lávate las manos y los utensilios de cocina después de manipular carne cruda.</p>",
      "ingredients": [],
      "utensils": [
        "57e2674fb7e8697d4b305372"
      ],
      "timers": [],
      "images": [
