      ],
      "videos": []
    },
    {
      "index": 2,
      "instructions": "\nCorta las patatas en gajos de 1-2 cm de grosor.\nCorta el pimiento en cuadrados de 2 cm.\nRetira los extremos del calabacín y córtalo por la mitad a lo largo. Corta en medias lunas de 0,5-1 cm.\n",
      "instructionsHTML": "<ul>\n<li dir=\"ltr\">Corta las <strong>patatas</strong> en gajos de 1-2 cm de grosor.</li>\n<li dir=\"ltr\">Corta el <strong>pimiento</strong> en cuadrados de 2 cm.</li>\n<li dir=\"ltr\">Retira los extremos del <strong>calabacín</strong> y córtalo por la mitad a lo largo. Corta en medias lunas de 0,5-1 cm.</li>\n</ul>",
      "instructionsMarkdown": "<ul>\n<li dir=\"ltr\">Corta las <strong>patatas</strong> en gajos de 1-2 cm de grosor.</li>\n<li dir=\"ltr\">Corta el <strong>pimiento</strong> en cuadrados de 2 cm.</li>\n<li dir=\"ltr\">Retira los extremos del <strong>calabacín</strong> y córtalo por la mitad a lo largo. Corta en medias lunas de 0,5-1 cm.</li>\n</ul>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/6849325c9f34f686e2db878e/step-f0316d10.jpg",
