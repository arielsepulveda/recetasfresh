  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC\nCorta las patatas en dados de 2-3 cm.\nRetira los extremos de la zanahoria y, con cortes diagoniales, divide en trozos de 2-3 cm.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC</li>\n<li>Corta las <strong>patatas</strong> en dados de 2-3 cm.</li>\n<li>Retira los extremos de la <strong>zanahoria</strong> y, con cortes diagoniales, divide en trozos de 2-3 cm.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC</li>\n<li>Corta las <strong>patatas</strong> en dados de 2-3 cm.</li>\n<li>Retira los extremos de la <strong>zanahoria</strong> y, con cortes diagoniales, divide en trozos de 2-3 cm.</li>\n</ul>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/68d68a271d20e752a6dba8eb/step-a4b74c00.jpg",
