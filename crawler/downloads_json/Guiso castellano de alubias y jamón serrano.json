  "steps": [
    {
      "index": 1,
      "instructions": "\n\n¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! Precalienta el horno a 220 ºC. Pela y lamina el ajo (ver cantidad en ingredientes). Deshoja y pica la mitad del romero (doble para 4p). Corta el pan chapata en tiras de 1-2 cm de grosor.\n \nSABÍAS QUE: Tan solo necesitarás un bote para pelar los ajos: mételos dentro y agita fuerte, estarán listos en 20 segundos.\n\n",
      "instructionsHTML": "<p><div dir=&quot;ltr&quot;>\n<div>\n<div id=&quot;waffle-rich-text-editor&quot; dir=&quot;ltr&quot;>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! Precalienta el horno a 220 ºC. Pela y lamina el <strong>ajo</strong> (ver cantidad en ingredientes). Deshoja y pica la mitad del <strong>romero</strong> (doble para 4p). Corta el <strong>pan chapata</strong> en tiras de 1-2 cm de grosor.</div>\n<div dir=&quot;ltr&quot;> </div>\n<div dir=&quot;ltr&quot;>SABÍAS QUE: Tan solo necesitarás un bote para pelar los ajos: mételos dentro y agita fuerte, estarán listos en 20 segundos.</div>\n</div>\n</div></p>",
      "instructionsMarkdown": "<div dir=\"ltr\">\n<div>\n<div id=\"waffle-rich-text-editor\" dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta! Precalienta el horno a 220 ºC. Pela y lamina el <strong>ajo</strong> (ver cantidad en ingredientes). Deshoja y pica la mitad del <strong>romero</strong> (doble para 4p). Corta el <strong>pan chapata</strong> en tiras de 1-2 cm de grosor.</div>\n<div dir=\"ltr\"> </div>\n<div dir=\"ltr\">SABÍAS QUE: Tan solo necesitarás un bote para pelar los ajos: mételos dentro y agita fuerte, estarán listos en 20 segundos.</div>\n</div>\n</div>",
      "ingredients": [],
