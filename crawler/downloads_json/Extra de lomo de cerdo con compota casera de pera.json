  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nCorta las patatas en gajos de 1-2 cm.\nPela la cebolla y córtala en tiras de 1 cm.\nEn una bandeja de horno con papel de horno, agrega las patatas, la cebolla, los tomates cherry y el ajo sin pelar.\nAdereza con la mitad de las especias mediterráneas, un chorrito de aceite, sal y pimienta y remueve.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Corta las <strong>patatas</strong> en gajos de 1-2 cm.</li>\n<li>Pela la <strong>cebolla</strong> y córtala en tiras de 1 cm.</li>\n<li>En una bandeja de horno con papel de horno, agrega las <strong>patatas,</strong> la <strong>cebolla,</strong> los <strong>tomates cherry</strong> y el <strong>ajo</strong> sin pelar.</li>\n<li>Adereza con la mitad de las <strong>especias mediterráneas,</strong> un chorrito de <strong>aceite, sal</strong> y <strong>pimienta</strong> y remueve.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Corta las <strong>patatas</strong> en gajos de 1-2 cm.</li>\n<li>Pela la <strong>cebolla</strong> y córtala en tiras de 1 cm.</li>\n<li>En una bandeja de horno con papel de horno, agrega las <strong>patatas,</strong> la <strong>cebolla,</strong> los <strong>tomates cherry</strong> y el <strong>ajo</strong> sin pelar.</li>\n<li>Adereza con la mitad de las <strong>especias mediterráneas,</strong> un chorrito de <strong>aceite, sal</strong> y <strong>pimienta</strong> y remueve.</li>\n</ul>",
      "ingredients": [],
