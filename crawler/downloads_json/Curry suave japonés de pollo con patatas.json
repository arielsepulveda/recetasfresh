    {
      "index": 6,
      "instructions": "\nSirve el arroz en un lado de los platos.\nSirve el curry japonés de pollo y verduras al otro lado.\n",
      "instructionsHTML": "<ul>\n<li>Sirve el <strong>arroz</strong> en un lado de los platos.</li>\n<li>Sirve el <strong>curry</strong> japonés de <strong>pollo</strong> y <strong>verduras</strong> al otro lado.</li>\n</ul>",
      "instructionsMarkdown": "<ul>\n<li>Sirve el <strong>arroz</strong> en un lado de los platos.</li>\n<li>Sirve el <strong>curry</strong> japonés de <strong>pollo</strong> y <strong>verduras</strong> al otro lado.</li>\n</ul>",
