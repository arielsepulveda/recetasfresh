  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nRalla la piel del limón y córtalo en gajos.\nEn un bol grande, mezcla las especias harissa, la ralladura de medio limón, un chorrito de aceite, sal y pimienta.\nAñade las alitas de pollo al bol y mezcla. \nCorta la patata en dados de 1-2 cm.\n\nRECUERDA: Lávate las manos y los utensilios de cocina después de manipular carne cruda.",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Ralla la piel del <strong>limón</strong> y córtalo en gajos.</li>\n<li>En un bol grande, mezcla las <strong>especias harissa</strong>, la ralladura de medio <strong>limón,</strong> un chorrito de <strong>aceite, sal</strong> y <strong>pimienta.</strong></li>\n<li>Añade las <strong>alitas de pollo</strong> al bol y mezcla. </li>\n<li>Corta la <strong>patata</strong> en dados de 1-2 cm.</li>\n</ul>\n<p>RECUERDA: Lávate las manos y los utensilios de cocina después de manipular carne cruda.</p>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Ralla la piel del <strong>limón</strong> y córtalo en gajos.</li>\n<li>En un bol grande, mezcla las <strong>especias harissa</strong>, la ralladura de medio <strong>limón,</strong> un chorrito de <strong>aceite, sal</strong> y <strong>pimienta.</strong></li>\n<li>Añade las <strong>alitas de pollo</strong> al bol y mezcla. </li>\n<li>Corta la <strong>patata</strong> en dados de 1-2 cm.</li>\n</ul>\n<p>RECUERDA: Lávate las manos y los utensilios de cocina después de manipular carne cruda.</p>",
      "ingredients": [],
      "utensils": [
        "57e2674fb7e8697d4b305385",
        "57e2674fb7e8697d4b305372"
      ],
      "timers": [],
