  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta el horno a 220ºC.\nCorta los tomates cherry por la mitad.\nPela la cebolla y córtala en tiras finas.\nColoca las bases de pizza en un bandeja de horno con papel de horno y agrega la passata de tomate encima, dejando 1 cm del borde sin cubrir.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Corta los <strong>tomates cherry</strong> por la mitad.</li>\n<li>Pela la <strong>cebolla</strong> y córtala en tiras finas.</li>\n<li>Coloca las <strong>bases de pizza</strong> en un bandeja de horno con papel de horno y agrega la <strong>passata de tomate</strong> encima, dejando 1 cm del borde sin cubrir.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta el horno a 220ºC.</li>\n<li>Corta los <strong>tomates cherry</strong> por la mitad.</li>\n<li>Pela la <strong>cebolla</strong> y córtala en tiras finas.</li>\n<li>Coloca las <strong>bases de pizza</strong> en un bandeja de horno con papel de horno y agrega la <strong>passata de tomate</strong> encima, dejando 1 cm del borde sin cubrir.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "5e3ad24dfcf61c18c30ff522"
      ],
      "timers": [],
      "images": [
