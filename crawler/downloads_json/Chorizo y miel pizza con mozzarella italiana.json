      "videos": []
    },
    {
      "index": 3,
      "instructions": "\nHornea las pizzas en la parte superior del horno 15-20 min o hasta que estén crujientes y doradas.\n",
      "instructionsHTML": "<ul>\n<li>Hornea las <strong>pizzas</strong> en la parte superior del horno 15-20 min o hasta que estén crujientes y doradas.</li>\n</ul>",
      "instructionsMarkdown": "<ul>\n<li>Hornea las <strong>pizzas</strong> en la parte superior del horno 15-20 min o hasta que estén crujientes y doradas.</li>\n</ul>",
