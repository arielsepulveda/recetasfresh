  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPela las patatas y córtalas en dados de 3 cm.\nPela y pica el ajo (ver cantidad en ingredientes).\nPela la zanahoria y córtala por la mitad a lo largo. Corta en medias lunas de 0,5-1 cm.\nCorta la panceta, el chorizo y la morcilla del compango por la mitad.\n",
      "instructionsHTML": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\">Pela las <strong>patatas</strong> y córtalas en dados de 3 cm.</li>\n<li dir=\"ltr\">Pela y pica el <strong>ajo</strong> (ver cantidad en ingredientes).</li>\n<li dir=\"ltr\">Pela la <strong>zanahoria</strong> y córtala por la mitad a lo largo. Corta en medias lunas de 0,5-1 cm.</li>\n<li dir=\"ltr\"><span>Corta la <strong>panceta,</strong> el <strong>chorizo</strong> y la <strong>morcilla</strong> del <strong>compango</strong> por la mitad.</span></li>\n</ul>",
      "instructionsMarkdown": "<p dir=\"ltr\">¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li dir=\"ltr\">Pela las <strong>patatas</strong> y córtalas en dados de 3 cm.</li>\n<li dir=\"ltr\">Pela y pica el <strong>ajo</strong> (ver cantidad en ingredientes).</li>\n<li dir=\"ltr\">Pela la <strong>zanahoria</strong> y córtala por la mitad a lo largo. Corta en medias lunas de 0,5-1 cm.</li>\n<li dir=\"ltr\"><span>Corta la <strong>panceta,</strong> el <strong>chorizo</strong> y la <strong>morcilla</strong> del <strong>compango</strong> por la mitad.</span></li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "57e2674fb7e8697d4b305379"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/677fad7f7160a0945c5e2ded/step-25e7ae00.jpg",
