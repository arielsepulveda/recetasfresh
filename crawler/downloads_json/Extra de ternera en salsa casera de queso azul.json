  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nPrecalienta tu horno a 220ºC.\nCorta las patatas en bastones de 1 cm de ancho y 3-4 cm de largo.\nRetira las puntas de las judías verdes y córtalas en tercios.\nPela y ralla el ajo.\nPela la cebolla y córtala en tiras finas.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta tu horno a 220ºC.</li>\n<li>Corta las <strong>patatas</strong> en bastones de 1 cm de ancho y 3-4 cm de largo.</li>\n<li>Retira las puntas de las <strong>judías verdes</strong> y córtalas en tercios.</li>\n<li>Pela y ralla el <strong>ajo</strong>.</li>\n<li>Pela la <strong>cebolla</strong> y córtala en tiras finas.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Precalienta tu horno a 220ºC.</li>\n<li>Corta las <strong>patatas</strong> en bastones de 1 cm de ancho y 3-4 cm de largo.</li>\n<li>Retira las puntas de las <strong>judías verdes</strong> y córtalas en tercios.</li>\n<li>Pela y ralla el <strong>ajo</strong>.</li>\n<li>Pela la <strong>cebolla</strong> y córtala en tiras finas.</li>\n</ul>",
      "ingredients": [],
      "utensils": [],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/693959c01101204cae74a440/step-f4e76500.jpg",
