  "steps": [
    {
      "index": 1,
      "instructions": "¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!\n\nSaca la ternera de la nevera.\nRetira el tallo de la berenjena y córtala en dados de 1-2 cm.\nEn una sartén, calienta un chorrito de aceite a fuego medio. Cocina la berenjena 5 min, removiendo.\nAgrega un chorrito de agua y cocina 4-5 min más, hasta que la berenjena quede tierna.\nReserva fuera de la sartén cuando esté lista.\n",
      "instructionsHTML": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Saca la<strong> ternera</strong> de la nevera.</li>\n<li>Retira el tallo de la <strong>berenjena</strong> y córtala en dados de 1-2 cm.</li>\n<li>En una sartén, calienta un chorrito de <strong>aceite</strong> a fuego medio. Cocina la <strong>berenjena</strong> 5 min, removiendo.</li>\n<li>Agrega un chorrito de <strong>agua</strong> y cocina 4-5 min más, hasta que la <strong>berenjena</strong> quede tierna.</li>\n<li>Reserva fuera de la sartén cuando esté lista.</li>\n</ul>",
      "instructionsMarkdown": "<p>¡Asegúrate de utilizar las cantidades indicadas a la izquierda para preparar tu receta!</p>\n<ul>\n<li>Saca la<strong> ternera</strong> de la nevera.</li>\n<li>Retira el tallo de la <strong>berenjena</strong> y córtala en dados de 1-2 cm.</li>\n<li>En una sartén, calienta un chorrito de <strong>aceite</strong> a fuego medio. Cocina la <strong>berenjena</strong> 5 min, removiendo.</li>\n<li>Agrega un chorrito de <strong>agua</strong> y cocina 4-5 min más, hasta que la <strong>berenjena</strong> quede tierna.</li>\n<li>Reserva fuera de la sartén cuando esté lista.</li>\n</ul>",
      "ingredients": [],
      "utensils": [
        "636bd5d9d7cc354a94046877"
      ],
      "timers": [],
      "images": [
        {
          "link": "https://d3hvwccx09j84u.cloudfront.net/0,0/6849326656532819dcc1a1dc/step-d134c900.jpeg",
